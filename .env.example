# Database
DATABASE_URL=postgresql://postgres:postgres@localhost/agnix_development
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Rails
RAILS_ENV=development
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=0
PORT=3001

# macOS fork safety (prevents Puma cluster crash on Apple Silicon)
OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# Solid Queue
SOLID_QUEUE_WORKERS=2
SOLID_QUEUE_AGENT_WORKERS=1

# App
APP_HOST=localhost:3001
ALLOWED_ORIGINS=http://localhost:3001

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_HOST=http://localhost:11434

# opencode.ai/zen proxy (OpenAI-compatible, free models)
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
LLM_MODEL=deepseek-v4-flash-free

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Email
POSTMARK_API_TOKEN=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Sentry
SENTRY_DSN=

# Storage (S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
