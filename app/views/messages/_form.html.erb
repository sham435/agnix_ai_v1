<%# Message form partial — used on conversation show and via turbo_stream replace. %>
<%= form_with model: [conversation, message],
  id: "message-form",
  class: "group relative rounded-[20px] border border-white/[0.08] bg-gradient-to-b from-white/[0.06] to-white/[0.02] p-1.5 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.04)] backdrop-blur-xl",
  data: { controller: "chat-input", chat_input_target: "form", turbo_stream: true } do |f| %>
  <div class="rounded-[16px] bg-[#0c0c0f] px-4 py-2">
    <%= f.text_area :content,
      rows: 1,
      placeholder: "Reply...",
      class: "w-full resize-none bg-transparent placeholder-zinc-600 text-[15px] leading-6 text-zinc-100 outline-none py-2",
      id: "message-input",
      data: { chat_input_target: "input" } %>

    <%= f.file_field :files,
      multiple: true,
      direct_upload: true,
      class: "hidden",
      data: { chat_input_target: "fileInput" } %>

    <div class="flex items-center justify-between pt-1">
      <div class="flex items-center gap-1">
        <button type="button" class="grid size-8 place-items-center rounded-lg hover:bg-white/[0.06] text-zinc-500 hover:text-zinc-200 transition"
          title="Attach file"
          data-action="chat-input#attach">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
        </button>
      </div>
      <button type="submit" class="grid size-8 place-items-center rounded-lg bg-gradient-to-b from-orange-400 to-orange-600 text-black hover:brightness-110 active:scale-95 transition">
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12l14-7-7 14-2-5-2z"/></svg>
      </button>
    </div>
  </div>
<% end %>
