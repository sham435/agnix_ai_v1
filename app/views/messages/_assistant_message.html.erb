<div class="flex gap-4 group/message relative isolate" data-chat-target="assistantMessage">
  <div class="size-8 rounded-lg bg-gradient-to-br from-orange-500/20 to-orange-600/10 border border-orange-500/20 grid place-items-center shrink-0 mt-1">
    <svg class="size-5 text-orange-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <circle cx="12" cy="12" r="3"/>
      <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83"/>
    </svg>
  </div>

  <div class="flex-1 min-w-0">
    <div class="flex items-baseline gap-2 flex-wrap">
      <span class="text-[13px] font-medium text-white"><%= message.agent&.name || "Assistant" %></span>
      <span class="text-[11px] text-zinc-600"><%= message.created_at&.strftime("%H:%M") %></span>
      <% if message.tokens %>
        <span class="text-[11px] text-zinc-700"><%= number_with_delimiter(message.tokens) %> tokens</span>
      <% end %>
    </div>

    <div class="mt-1 markdown-body text-[15px] leading-7">
      <% if local_assigns.fetch(:streaming, false) %>
        <div class="text-zinc-400 streaming-cursor" data-chat-target="streamingContent">
          Thinking...
        </div>
      <% else %>
        <div class="prose prose-invert max-w-none break-words">
          <%= render_markdown(message.content) %>
        </div>
      <% end %>
    </div>

    <% if message.has_tool_calls? %>
      <div class="mt-3 space-y-2">
        <% message.tool_calls.each do |tool_call| %>
          <details class="rounded-lg border border-white/[0.06] bg-white/[0.02] overflow-hidden">
            <summary class="px-3 py-2 text-[13px] text-zinc-400 cursor-pointer hover:bg-white/[0.04] list-none">
              <svg class="size-3.5 inline mr-1 -mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
              Tool: <%= tool_call.dig("function", "name") || tool_call.dig(:function, :name) %>
            </summary>
            <pre class="px-3 py-2 text-[12px] text-zinc-500 overflow-x-auto"><%= JSON.pretty_generate(tool_call) rescue tool_call.to_s %></pre>
          </details>
        <% end %>
      </div>
    <% end %>

    <!-- Action buttons -->
    <div class="flex items-center gap-1 mt-2 opacity-0 group-hover/message:opacity-100 transition relative z-10 isolate">
      <button class="grid size-7 place-items-center rounded-lg hover:bg-white/[0.06] text-zinc-600 hover:text-zinc-300 transition" title="Copy" data-action="click->chat#copy">
        <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
      </button>
      <button class="grid size-7 place-items-center rounded-lg hover:bg-white/[0.06] text-zinc-600 hover:text-zinc-300 transition" title="Regenerate">
        <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 2v6h-6"/>
          <path d="M3 12a9 9 0 0 1 15-6.7L21 8"/>
        </svg>
      </button>
      <button class="grid size-7 place-items-center rounded-lg hover:bg-white/[0.06] text-zinc-600 hover:text-zinc-300 transition" title="Good response">
        <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M7 10v12"/>
          <path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.1L12 2a3.13 3.13 0 0 1 3 3.88Z"/>
        </svg>
      </button>
    </div>
  </div>
</div>
