<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? yield(:title) : "Shams شمس AgentOS" %></title>
  <meta name="description" content="AI Agentic Agent Platform - Better Coding, Smarter Agents">
  <meta name="csrf-token" content="<%= form_authenticity_token %>">

  <%= csp_meta_tag %>
  <%= csrf_meta_tags %>
  <%= action_cable_meta_tag %>

  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+Arabic:wght@400;500;700&display=swap" rel="stylesheet">

  <style>
    .font-arabic { font-family: 'Noto Sans Arabic', 'Inter', sans-serif; }
    .font-sans { font-family: 'Inter', system-ui, sans-serif; }
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-thumb { background: #2a2a30; border-radius: 999px; }
    ::-webkit-scrollbar-thumb:hover { background: #3a3a42; }
    .glass { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
  </style>

  <%= yield :head %>
  <%= javascript_importmap_tags %>
</head>

<body class="bg-canvas text-zinc-200 font-sans antialiased min-h-screen selection:bg-orange-500/20 selection:text-orange-300">
  <% if notice %>
    <div class="fixed top-4 right-4 z-50 rounded-xl bg-emerald-500/10 border border-emerald-500/20 px-4 py-3 text-sm text-emerald-400" data-controller="flash">
      <%= notice %>
    </div>
  <% end %>
  <% if alert %>
    <div class="fixed top-4 right-4 z-50 rounded-xl bg-red-500/10 border border-red-500/20 px-4 py-3 text-sm text-red-400" data-controller="flash">
      <%= alert %>
    </div>
  <% end %>

  <%= yield %>

  <%= turbo_frame_tag "modal" %>

  <div id="toast-container" class="fixed top-4 left-1/2 -translate-x-1/2 z-[60] pointer-events-none space-y-2"></div>
</body>
</html>
