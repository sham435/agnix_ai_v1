<!-- Header -->
<header class="sticky top-0 z-20 flex h-[64px] items-center justify-between gap-3 border-b border-white/[0.06] bg-[#080809]/80 glass px-4">
  <div class="flex items-center gap-2">
    <button id="menuBtn" class="lg:hidden grid size-9 place-items-center rounded-xl bg-white/[0.04] hover:bg-white/[0.08] text-zinc-300">
      <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
    <h1 class="text-[16px] font-semibold text-white">Shams <span class="font-arabic text-orange-400">شمس</span> AgentOS</h1>
  </div>

  <div class="flex items-center gap-2">
    <div class="hidden sm:flex items-center gap-1.5 rounded-xl bg-white/[0.04] px-3 py-2 text-[13px] text-zinc-300">
      <span class="size-2 rounded-full bg-emerald-500 animate-pulse"></span>
      Rails 8.1 Live
    </div>
    <div class="size-8 rounded-full bg-gradient-to-br from-orange-400 to-orange-600 grid place-items-center text-xs font-bold text-black">
      <%= current_user.name.to_s.first.upcase %>
    </div>
  </div>
</header>

<!-- Chat Home -->
<main class="flex-1 overflow-y-auto">
  <div class="mx-auto max-w-[900px] px-6 py-16 lg:py-24">
    <!-- Hero -->
    <div class="text-center">
      <div class="mx-auto mb-8 grid size-24 place-items-center">
        <svg viewBox="0 0 100 100" class="size-24 drop-shadow-[0_0_60px_rgba(255,138,0,0.4)]">
          <defs>
            <radialGradient id="glow" cx="50%" cy="50%">
              <stop offset="0%" stop-color="#FFB366" stop-opacity="1"/>
              <stop offset="100%" stop-color="#FF7A00" stop-opacity="0"/>
            </radialGradient>
            <linearGradient id="sunGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#FFA500"/>
              <stop offset="100%" stop-color="#FF7A00"/>
            </linearGradient>
          </defs>
          <circle cx="50" cy="50" r="45" fill="url(#glow)"/>
          <g fill="url(#sunGrad2)" stroke="url(#sunGrad2)" stroke-linejoin="round">
            <path d="M50 8 L54 30 L68 16 L60 38 L84 32 L64 48 L92 58 L64 64 L80 88 L56 70 L50 96 L44 70 L20 88 L36 64 L8 58 L36 48 L16 32 L40 38 L32 16 L46 30 Z"/>
          </g>
        </svg>
      </div>
      <h1 class="text-[42px] lg:text-[56px] font-semibold tracking-tight text-white">
        Shams <span class="font-arabic text-orange-400">شمس</span> AgentOS
      </h1>
      <p class="mt-3 text-[18px] text-zinc-400">Better Coding, Smarter Agents</p>
      <p class="mt-1 text-[13px] text-zinc-600">Powered by Rails 8.1 • Solid Queue • Kamal 2 • Action Cable</p>
    </div>

    <!-- Input -->
    <div class="mx-auto mt-14 max-w-[720px]">
      <%= form_with url: conversations_path, method: :post, class: "group relative rounded-[28px] border border-white/[0.08] bg-gradient-to-b from-white/[0.06] to-white/[0.02] p-1.5 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.04),0_20px_80px_rgba(0,0,0,0.5)] backdrop-blur-xl", data: { turbo_stream: true, controller: "chat-input" } do |f| %>
        <div class="rounded-[22px] bg-[#0c0c0f] px-4 py-3">
          <%= f.text_area :content,
            rows: 1,
            placeholder: "Ask Anything...",
            class: "w-full resize-none bg-transparent placeholder-zinc-600 text-[16px] leading-7 text-zinc-100 outline-none py-2",
            id: "composer-input",
            data: { chat_input_target: "input" } %>
          <%= f.hidden_field :agent_id, value: params[:agent_id] || Agent.where(is_active: true).first&.id %>

          <div class="flex items-center justify-between pt-2 border-t border-white/[0.06] mt-2">
            <div class="flex items-center gap-1.5">
              <button type="button" class="grid size-9 place-items-center rounded-xl hover:bg-white/[0.06] text-zinc-500 hover:text-zinc-200 transition" title="Attach">
                <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
              </button>
              <button type="button" class="flex items-center gap-1.5 rounded-xl hover:bg-white/[0.06] px-2.5 py-2 text-[13px] text-zinc-400 hover:text-zinc-200 transition">
                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                Tools
              </button>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="hidden sm:block text-[12px] text-zinc-600 mr-1">⌘ ↵</span>
              <button type="submit" class="grid size-9 place-items-center rounded-xl bg-gradient-to-b from-orange-400 to-orange-600 text-black hover:brightness-110 active:scale-95 transition shadow-lg shadow-orange-900/30">
                <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12l14-7-7 14-2-5-2z"/></svg>
              </button>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Suggestions -->
      <div class="mt-4 flex flex-wrap justify-center gap-2">
        <button class="suggest px-3 py-1.5 rounded-full bg-white/[0.04] hover:bg-white/[0.08] border border-white/[0.06] text-[13px] text-zinc-400 hover:text-zinc-200 transition">Generate a Rails 8.1 controller</button>
        <button class="suggest px-3 py-1.5 rounded-full bg-white/[0.04] hover:bg-white/[0.08] border border-white/[0.06] text-[13px] text-zinc-400 hover:text-zinc-200 transition">Explain Solid Queue vs Sidekiq</button>
        <button class="suggest px-3 py-1.5 rounded-full bg-white/[0.04] hover:bg-white/[0.08] border border-white/[0.06] text-[13px] text-zinc-400 hover:text-zinc-200 transition">Create agent swarm workflow</button>
      </div>
    </div>

    <!-- Features grid -->
    <div class="mt-20 grid grid-cols-1 sm:grid-cols-3 gap-3 max-w-[720px] mx-auto">
      <div class="group rounded-2xl border border-white/[0.06] bg-gradient-to-b from-white/[0.04] to-transparent p-4 hover:border-orange-500/30 transition">
        <div class="size-10 rounded-xl bg-orange-500/10 text-orange-400 grid place-items-center mb-3">
          <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/></svg>
        </div>
        <h3 class="font-medium text-white">Better Coding</h3>
        <p class="text-[13px] text-zinc-500 mt-1">Rails 8.1 generators, linters & tests in one flow.</p>
      </div>
      <div class="group rounded-2xl border border-white/[0.06] bg-gradient-to-b from-white/[0.04] to-transparent p-4 hover:border-orange-500/30 transition">
        <div class="size-10 rounded-xl bg-orange-500/10 text-orange-400 grid place-items-center mb-3">
          <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
        </div>
        <h3 class="font-medium text-white">Smarter Agents</h3>
        <p class="text-[13px] text-zinc-500 mt-1">Multi-agent swarm with memory & tool use.</p>
      </div>
      <div class="group rounded-2xl border border-white/[0.06] bg-gradient-to-b from-white/[0.04] to-transparent p-4 hover:border-orange-500/30 transition">
        <div class="size-10 rounded-xl bg-orange-500/10 text-orange-400 grid place-items-center mb-3">
          <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.9 4.9l2.8 2.8"/><path d="M16.3 16.3l2.8 2.8"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.9 19.1l2.8-2.8"/><path d="M16.3 7.7l2.8-2.8"/></svg>
        </div>
        <h3 class="font-medium text-white">Rails 8.1 Native</h3>
        <p class="text-[13px] text-zinc-500 mt-1">Solid Cable, Queue, Cache built-in.</p>
      </div>
    </div>
  </div>
</main>

<%= render "shared/sidebar_js" %>
