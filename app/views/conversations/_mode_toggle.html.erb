<div id="mode_toggle" class="flex items-center gap-2">
  <div class="flex items-center bg-white/[0.04] rounded-full p-1 border border-white/[0.06]">
    <% modes = [
      ["manual_plan", "Manual Plan"],
      ["auto_plan", "Auto Plan"],
      ["manual_build", "Manual Build"],
      ["auto_build", "Auto Build"]
    ] %>
    <% modes.each do |key, label| %>
      <%= button_to label,
          conversation_path(@conversation, conversation: { mode: key }),
          method: :patch,
          form: { data: { turbo_stream: true } },
          class: "px-3 py-1.5 text-[13px] rounded-full transition whitespace-nowrap #{@conversation.mode.to_s == key ? 'bg-orange-500/20 text-orange-300' : 'text-zinc-400 hover:text-zinc-200'}" %>
    <% end %>
  </div>

  <%= button_to stop_conversation_path(@conversation),
      method: :post,
      class: "size-9 grid place-items-center rounded-full bg-red-500/20 hover:bg-red-500/30 text-red-400 transition",
      title: "Interrupt",
      form: { data: { turbo_stream: true } } do %>
    <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><rect x="7" y="7" width="10" height="10" rx="1"/></svg>
    <span class="sr-only">Stop</span>
  <% end %>
</div>
