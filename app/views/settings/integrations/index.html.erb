<%= render "layouts/chat_layout" do %>
  <header class="sticky top-0 z-20 flex h-[64px] items-center justify-between gap-3 border-b border-white/[0.06] bg-[#080809]/80 glass px-4">
    <div class="flex items-center gap-2">
      <button id="menuBtn" class="lg:hidden grid size-9 place-items-center rounded-xl bg-white/[0.04] hover:bg-white/[0.08] text-zinc-300">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <h1 class="text-[16px] font-semibold text-white">Integrations</h1>
    </div>
  </header>

  <main class="flex-1 overflow-y-auto p-6">
    <div class="mx-auto max-w-[700px]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @available_providers.each do |provider| %>
          <% integration = @integrations.find_by(provider: provider) %>
          <div class="card">
            <div class="flex items-start justify-between">
              <div class="flex items-center gap-3">
                <div class="size-10 rounded-xl bg-white/[0.06] grid place-items-center text-zinc-400">
                  <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                </div>
                <div>
                  <h3 class="font-medium text-white capitalize"><%= provider %></h3>
                  <% if integration %>
                    <p class="text-[12px] text-zinc-500">
                      <%= integration.is_active ? "Active" : "Inactive" %>
                      <% if integration.last_used_at %>
                        • Last used <%= time_ago(integration.last_used_at) %>
                      <% end %>
                    </p>
                  <% else %>
                    <p class="text-[12px] text-zinc-600">Not configured</p>
                  <% end %>
                </div>
              </div>
              <%= status_badge(integration&.is_active ? "active" : "inactive") %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </main>

  <%= render "shared/sidebar_js" %>
<% end %>
