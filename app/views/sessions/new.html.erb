<div class="flex min-h-screen items-center justify-center bg-gradient-to-b from-[#0a0a0c] to-[#050507] px-4">
  <div class="w-full max-w-md">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="mx-auto mb-4 grid size-16 place-items-center">
        <svg viewBox="0 0 100 100" class="size-16 drop-shadow-[0_0_40px_rgba(255,138,0,0.4)]">
          <defs>
            <linearGradient id="sunGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#FFA500"/>
              <stop offset="100%" stop-color="#FF7A00"/>
            </linearGradient>
          </defs>
          <g fill="url(#sunGrad)" stroke="url(#sunGrad)" stroke-linejoin="round">
            <path d="M50 12 L53.5 32 L65 20 L58 38 L78 35 L62 48 L82 58 L62 62 L72 80 L54 68 L50 88 L46 68 L28 80 L38 62 L18 58 L38 48 L22 35 L42 38 L35 20 L46.5 32 Z" fill-opacity="0.95"/>
          </g>
        </svg>
      </div>
      <h1 class="text-2xl font-semibold text-white">Shams <span class="font-arabic text-orange-400">شمس</span></h1>
      <p class="text-zinc-500 text-sm mt-1">Sign in to AgentOS</p>
    </div>

    <!-- Login Form -->
    <div class="card">
      <%= form_with url: login_path, method: :post, class: "space-y-4" do |f| %>
        <div>
          <label class="block text-[13px] font-medium text-zinc-300 mb-1">Email</label>
          <%= f.email_field :email,
            value: params[:email],
            placeholder: "you@example.com",
            class: "input-field",
            autofocus: true,
            required: true %>
        </div>

        <div>
          <label class="block text-[13px] font-medium text-zinc-300 mb-1">Password</label>
          <%= f.password_field :password,
            placeholder: "••••••••",
            class: "input-field",
            required: true %>
        </div>

        <button type="submit" class="btn-primary w-full">Sign In</button>
      <% end %>

      <!-- OAuth -->
      <div class="mt-6">
        <div class="relative">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-white/[0.06]"></div></div>
          <div class="relative flex justify-center text-[12px]"><span class="px-2 text-zinc-600 bg-panel">or continue with</span></div>
        </div>

        <div class="mt-4 grid grid-cols-2 gap-3">
          <%= button_to "/auth/google", method: :post, class: "btn-secondary w-full justify-center text-[13px]", data: { turbo: false } do %>
            <svg class="size-4 mr-2" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Google
          <% end %>
          <%= button_to "/auth/github", method: :post, class: "btn-secondary w-full justify-center text-[13px]", data: { turbo: false } do %>
            <svg class="size-4 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 2.958-.322.887-.002 1.76.118 2.596.346 1.873-1.358 4.278-2.223 6.878-2.25 2.552.014 5.286 1.132 6.518 3.226.658 1.545.17 2.875.092 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          <% end %>
        </div>
      </div>
    </div>

    <p class="text-center text-[13px] text-zinc-600 mt-6">
      Don't have an account? Contact your organization admin.
    </p>
  </div>
</div>
