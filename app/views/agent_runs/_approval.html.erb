<div id="agent-run-<%= run.id %>" class="rounded-xl border border-amber-500/20 bg-amber-500/5 p-4 space-y-3">
  <div class="flex items-center gap-2">
    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-medium border <%= mode_badge_classes(run.mode) %>">
      <%= run.mode.humanize %>
    </span>
    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-medium border <%= status_badge_classes("awaiting_approval") %>">
      <span class="size-1.5 rounded-full bg-amber-400 animate-pulse"></span>
      Awaiting approval
    </span>
  </div>
  <div class="flex items-center gap-2 text-sm text-amber-300">
    <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 9v4m0 4h.01"/><circle cx="12" cy="12" r="10"/>
    </svg>
    Plan ready — review and approve to execute
  </div>

  <div class="space-y-2">
    <% run.todos.order(:position).each do |todo| %>
      <div class="flex items-center gap-2 text-sm text-zinc-300">
        <span class="size-3 rounded-full border border-zinc-600 shrink-0"></span>
        <%= todo.title %>
      </div>
    <% end %>
  </div>

  <div class="flex items-center gap-2 pt-1">
    <button data-action="agent-plan#resume" data-agent-run-id="<%= run.id %>"
            class="rounded-full bg-emerald-600 hover:bg-emerald-500 px-4 py-1.5 text-xs font-medium text-white transition">
      <svg class="size-3.5 inline mr-1 -mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 13l4 4L19 7"/>
      </svg>
      Approve & Execute
    </button>
    <button data-action="agent-plan#interrupt" data-agent-run-id="<%= run.id %>"
            class="rounded-full bg-zinc-800 hover:bg-zinc-700 px-4 py-1.5 text-xs text-zinc-400 transition">
      Cancel
    </button>
  </div>
</div>
