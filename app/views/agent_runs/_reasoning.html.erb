<div id="reasoning-<%= run.id %>" class="mt-3">
  <details class="group rounded-xl border border-white/[0.08] bg-white/[0.02] open:bg-white/[0.04] transition">
    <summary class="flex items-center gap-2 px-3 py-2 cursor-pointer list-none">
      <svg class="size-4 text-orange-400 group-open:rotate-90 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 18l6-6-6-6"/>
      </svg>
      <span class="text-[13px] font-medium text-zinc-300">Thinking</span>
      <span class="text-[11px] text-zinc-500"><%= run.reasoning_steps&.size || 0 %> steps</span>
    </summary>
    <div class="px-3 pb-3 space-y-2 max-h-64 overflow-y-auto">
      <% (run.reasoning_steps || []).each do |s| %>
        <div class="flex gap-2 text-[13px]">
          <span class="text-zinc-600 font-mono text-[11px] mt-0.5"><%= Time.parse(s["t"]).strftime("%H:%M:%S") %></span>
          <div class="flex-1">
            <div class="text-zinc-200"><%= s["step"] %></div>
            <% if s["detail"].present? %>
              <div class="text-zinc-500 text-[12px] mt-0.5"><%= s["detail"] %></div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </details>
</div>
