<%= form_with model: agent, class: "space-y-6" do |f| %>
  <div class="card space-y-6">
    <h2 class="text-[15px] font-medium text-white">Basic Info</h2>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-[13px] font-medium text-zinc-300 mb-1">Name</label>
        <%= f.text_field :name, placeholder: "My Agent", class: "input-field", required: true %>
      </div>
      <div>
        <label class="block text-[13px] font-medium text-zinc-300 mb-1">Slug</label>
        <%= f.text_field :slug, placeholder: "my-agent", class: "input-field" %>
        <p class="text-[11px] text-zinc-600 mt-1">Auto-generated from name</p>
      </div>
    </div>

    <div>
      <label class="block text-[13px] font-medium text-zinc-300 mb-1">Description</label>
      <%= f.text_area :description, rows: 2, placeholder: "What does this agent do?", class: "input-field resize-none" %>
    </div>
  </div>

  <div class="card space-y-6">
    <h2 class="text-[15px] font-medium text-white">Model & Provider</h2>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-[13px] font-medium text-zinc-300 mb-1">Provider</label>
        <%= f.select :provider, Agent.providers.map { |name, val| [name.titleize, val] }, {}, class: "input-field" %>
      </div>
      <div>
        <label class="block text-[13px] font-medium text-zinc-300 mb-1">Model</label>
        <%= f.select :model, Agent::MODELS.values.flatten.map { |m| [m, m] }, {}, class: "input-field" %>
      </div>
    </div>

    <div>
      <label class="block text-[13px] font-medium text-zinc-300 mb-1">System Prompt</label>
      <%= f.text_area :system_prompt, rows: 8,
        placeholder: "You are a helpful AI assistant...",
        class: "input-field resize-none font-mono text-[13px]" %>
    </div>
  </div>

  <div class="card space-y-6">
    <h2 class="text-[15px] font-medium text-white">Tools</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
      <% Agents::ToolRegistry.all.each do |tool| %>
        <label class="flex items-center gap-2 rounded-xl bg-white/[0.04] px-3 py-2.5 hover:bg-white/[0.06] cursor-pointer transition">
              <%= check_box_tag "agent[tools][]", tool[:name], agent.persisted? ? (agent.tools.include?(tool[:name]) || agent.tools.any? { |t| t.is_a?(Hash) && t["name"] == tool[:name] }) : true, class: "rounded border-zinc-600 bg-white/[0.04] text-orange-500 focus:ring-orange-500/20" %>
          <span class="text-[13px] text-zinc-300"><%= tool[:name].titleize %></span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3">
    <%= link_to "Cancel", agents_path, class: "btn-secondary" %>
    <%= f.submit submit_label, class: "btn-primary" %>
  </div>
<% end %>
