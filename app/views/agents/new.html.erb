<%= render "layouts/chat_layout" do %>
  <!-- Header -->
  <header class="sticky top-0 z-20 flex h-[64px] items-center justify-between gap-3 border-b border-white/[0.06] bg-[#080809]/80 glass px-4">
    <%= link_to agents_path, class: "flex items-center gap-2 text-zinc-400 hover:text-zinc-200 transition" do %>
      <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
      <span class="text-[14px]">Back to Agents</span>
    <% end %>
    <h1 class="text-[16px] font-semibold text-white">New Agent</h1>
    <div></div>
  </header>

  <!-- Form -->
  <main class="flex-1 overflow-y-auto p-6">
    <div class="mx-auto max-w-[700px]">
      <%= render "form", agent: @agent, submit_label: "Create Agent" %>
    </div>
  </main>

  <%= render "shared/sidebar_js" %>
<% end %>
