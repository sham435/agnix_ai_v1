<div class="group rounded-2xl border border-white/[0.06] bg-gradient-to-b from-white/[0.04] to-transparent p-4 hover:border-orange-500/30 transition">
  <div class="flex items-start justify-between">
    <div class="flex items-center gap-3">
      <div class="size-10 rounded-xl bg-orange-500/10 text-orange-400 grid place-items-center">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <circle cx="12" cy="12" r="3"/>
          <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83"/>
        </svg>
      </div>
      <div>
        <h3 class="font-medium text-white"><%= agent.name %></h3>
        <p class="text-[13px] text-zinc-500"><%= agent.provider.titleize %> • <%= agent.model %></p>
      </div>
    </div>
    <%= status_badge(agent.is_active ? "active" : "inactive") %>
  </div>

  <% if agent.description.present? %>
    <p class="mt-3 text-[13px] text-zinc-400 line-clamp-2"><%= agent.description %></p>
  <% end %>

  <% if agent.tools.any? %>
    <div class="flex flex-wrap gap-1 mt-3">
      <% agent.enabled_tools.each do |tool| %>
        <span class="text-[11px] px-2 py-0.5 rounded-full bg-white/[0.06] text-zinc-400">
          <%= tool[:name] || tool["name"] %>
        </span>
      <% end %>
    </div>
  <% end %>

  <% if show_actions %>
    <div class="flex items-center gap-2 mt-4 pt-3 border-t border-white/[0.04]">
      <%= link_to agent_path(agent), class: "text-[13px] text-orange-400 hover:text-orange-300" do %>
        Open
      <% end %>
      <%= link_to edit_agent_path(agent), class: "text-[13px] text-zinc-500 hover:text-zinc-300" do %>
        Edit
      <% end %>
    </div>
  <% end %>
</div>
